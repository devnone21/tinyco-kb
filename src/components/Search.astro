---
// Pagefind search UI. Index is generated by `pagefind --site dist`
// after `astro build` (wired in package.json `build` script).
---
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script is:inline src="/pagefind/pagefind-ui.js" defer></script>

<div id="search" class="pagefind-ui"></div>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.PagefindUI) {
      new window.PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        excerptLength: 30,
      });
    }
  });
</script>
