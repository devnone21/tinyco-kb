---
const path = Astro.url.pathname;
const isActive = (p: string) =>
  p === '/' ? path === '/' : path.startsWith(p);
---
<header class="site-nav">
  <div class="container nav-inner">
    <a href="/" class="brand">📚 Tony's KB</a>
    <nav>
      <a href="/" class={isActive('/') ? 'active' : ''}>Home</a>
      <a href="/kb" class={isActive('/kb') ? 'active' : ''}>Knowledge</a>
      <a href="/updates" class={isActive('/updates') ? 'active' : ''}>Updates</a>
      <a href="/tags" class={isActive('/tags') ? 'active' : ''}>Tags</a>
      <a href="/rss.xml">RSS</a>
      <a href="/search" class={isActive('/search') ? 'active' : ''}>Search</a>
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" type="button">◐</button>
    </nav>
  </div>
</header>

<script is:inline>
  // Theme toggle: cycles auto → light → dark → auto
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    var order = ['auto', 'light', 'dark'];
    function apply(t) { document.documentElement.setAttribute('data-theme', t); }
    btn.addEventListener('click', function () {
      var cur = document.documentElement.getAttribute('data-theme') || 'auto';
      var next = order[(order.indexOf(cur) + 1) % order.length];
      try { localStorage.setItem('theme', next); } catch (e) {}
      apply(next);
    });
  })();
</script>
