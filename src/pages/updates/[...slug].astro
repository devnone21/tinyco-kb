---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('updates');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'updates'> }
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Base title={entry.data.title} description={`Update from ${entry.data.source ?? 'manual'}`}>
  <article class={`severity-${entry.data.severity ?? 'info'}`} style="padding-left:1rem">
    <p class="meta">
      <time datetime={entry.data.pubDate.toISOString()}>
        {entry.data.pubDate.toLocaleString()}
      </time>
      {entry.data.source && <> · source: <span class="tag">{entry.data.source}</span></>}
      <span class={`tag severity-${entry.data.severity ?? 'info'}`}>{entry.data.severity}</span>
    </p>
    <h1>{entry.data.title}</h1>
    <Content />
  </article>
</Base>
