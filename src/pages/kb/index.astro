---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('knowledge', ({ data }) => !data.draft))
  .sort((a, b) => +b.data.pubDate - +a.data.pubDate);
---
<Base title="Knowledge" description="Knowledge base articles">
  <h1>Knowledge</h1>
  <p class="meta">{entries.length} article{entries.length === 1 ? '' : 's'}.</p>
  <ul class="cards">
    {entries.map((entry) => (
      <li>
        <a href={`/kb/${entry.slug}`}>{entry.data.title}</a>
        {entry.data.description && <p class="meta">{entry.data.description}</p>}
        <div class="meta">
          <time datetime={entry.data.pubDate.toISOString()}>
            {entry.data.pubDate.toLocaleDateString()}
          </time>
          {entry.data.tags?.map((t) => <span class="tag">{t}</span>)}
        </div>
      </li>
    ))}
  </ul>
</Base>
