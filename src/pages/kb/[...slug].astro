---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('knowledge', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'knowledge'> }
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Base title={entry.data.title} description={entry.data.description}>
  <article>
    <p class="meta">
      <time datetime={entry.data.pubDate.toISOString()}>
        {entry.data.pubDate.toLocaleDateString()}
      </time>
      {entry.data.updated && (
        <span> · updated {entry.data.updated.toLocaleDateString()}</span>
      )}
      {entry.data.tags?.map((t) => <span class="tag">{t}</span>)}
    </p>
    <h1>{entry.data.title}</h1>
    <Content />
  </article>
</Base>
